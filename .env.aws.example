# FluxForge — AWS deployment config
# Copy to .env.aws and fill in your values:
#   cp .env.aws.example .env.aws
#   chmod 600 .env.aws      ← keep this file private, never commit it

# ── AWS account ──────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=123456789012          # 12-digit AWS account ID
AWS_REGION=ap-southeast-1            # region where your ECR + EC2 live

# ── ECR repository names (just the name, not the full URI) ───────────────────
ECR_REPO_WEB=fluxforge-web
ECR_REPO_SERVER=fluxforge-server

# ── EC2 instance ─────────────────────────────────────────────────────────────
EC2_HOST=ec2-xx-xx-xx-xx.compute.amazonaws.com   # Public DNS or Elastic IP
EC2_USER=ec2-user                                  # Amazon Linux 2023: ec2-user  |  Ubuntu: ubuntu
EC2_KEY_NAME=fluxforge-ec2                         # Name of the key pair in AWS (script creates it)
EC2_KEY_PATH=~/.ssh/fluxforge-ec2.pem             # Where to save the PEM file locally

# ── Remote paths ─────────────────────────────────────────────────────────────
REMOTE_APP_DIR=/home/ec2-user/fluxforge            # Directory on EC2 that holds compose files

# ── Health check URL (defaults to http://EC2_HOST if left blank) ─────────────
APP_URL=http://ec2-xx-xx-xx-xx.compute.amazonaws.com
