{
  "productName": "FluxForge",
  "version": "1.0.0",
  "identifier": "io.fluxforge.desktop",
  "build": {
    "beforeDevCommand":   "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl":             "http://localhost:5173",
    "frontendDist":       "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label":      "main",
        "title":      "FluxForge Desktop",
        "width":      1200,
        "height":     800,
        "minWidth":   900,
        "minHeight":  600,
        "resizable":  true,
        "fullscreen": false,
        "decorations":true,
        "center":     true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
